        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml BankManagementSystem_ClassDiagram\n\nskinparam classAttributeIconSize 0\nskinparam classFontSize 12\nskinparam classFontStyle bold\nskinparam classBackgroundColor #FAFAFA\nskinparam classBorderColor #34495E\nskinparam classHeaderBackgroundColor #2C3E50\nskinparam classHeaderFontColor #FFFFFF\nskinparam arrowColor #2C3E50\nskinparam arrowThickness 1.5\nskinparam groupInheritance 2\nskinparam nodesep 50\nskinparam ranksep 70\n\n&#39; ================================================================\n&#39;  PACKAGE: USER MANAGEMENT\n&#39; ================================================================\npackage \&quot;User Management\&quot; #EBF5FB {\n\n  abstract class User {\n    - userID : String\n    - username : String\n    - passwordHash : String\n    - email : String\n    - phoneNumber : String\n    - isActive : boolean\n    - isLocked : boolean\n    - failedLoginCount : int\n    - sessionToken : String\n    - sessionExpiry : DateTime\n    - lastLogin : DateTime\n    + login(username: String, password: String) : boolean\n    + verifyOTP(otp: String) : boolean\n    + resendOTP() : void\n    + logout() : void\n    + lockAccount() : void\n    + unlockAccount() : void\n    + resetPassword(newPassword: String) : void\n  }\n\n  class Administrator {\n    - adminLevel : String\n    + createUserProfile(data: Map) : User\n    + modifyUserProfile(userID: String, data: Map) : void\n    + deleteUserProfile(userID: String) : void\n    + assignPermissionsToRole(roleID: String, permissions: List) : void\n    + removePermissionsFromRole(roleID: String, permissions: List) : void\n    + viewSystemHealthDashboard() : HealthReport\n    + scheduleMaintenanceWindow(date: DateTime, duration: int) : void\n    + applySystemUpdate(patchID: String) : void\n    + viewAuditLog(filters: Map) : List\n    + sendMaintenanceNotification(message: String) : void\n  }\n\n  class BankDirector {\n    - assignedBranches : List\n    + viewFundAllocations(filters: Map) : List\n    + allocateFunds(sourceUnit: String, destUnit: String, amount: double) : boolean\n    + redistributeFunds(sourceUnit: String, destUnit: String, amount: double) : boolean\n    + setInterestRate(accountType: String, rate: double) : void\n    + setFeeStructure(feeType: String, value: double) : void\n    + setBankPolicy(category: String, value: String, effectiveDate: Date) : void\n    + viewAnalyticsReport(type: String, params: Map) : Report\n    + viewAuditLog(filters: Map) : List\n    + reviewFraudAlert(alertID: String, action: String) : void\n    + approveLoan(loanApplicationID: String) : boolean\n    + rejectLoan(loanApplicationID: String) : void\n    + delegateAlertToStaff(alertID: String, staffID: String) : void\n  }\n\n  class BankStaff {\n    - department : String\n    - branchID : String\n    + searchCustomer(query: String) : Customer\n    + createCustomerProfile(data: Map) : Customer\n    + createAccount(customerID: String, type: String, data: Map) : BankAccount\n    + updateAccountDetails(accountID: String, data: Map) : void\n    + updateCustomerKYC(customerID: String, docs: List) : void\n    + verifyKYC(customerID: String) : boolean\n    + reviewLoanApplication(loanAppID: String) : void\n    + approveLoan(loanAppID: String) : boolean\n    + rejectLoan(loanAppID: String) : void\n    + sendLoanToDirector(loanAppID: String) : void\n    + generateStatement(accountID: String, period: DateRange) : Statement\n    + manageComplaint(complaintID: String, action: String) : void\n    + escalateComplaint(complaintID: String) : void\n    + processBulkPayment(batchFile: File) : BatchReport\n    + investigateFlaggedAccount(accountID: String) : void\n    + applyCorrectiveAction(caseID: String, action: String) : void\n    + markAlertAsFalsePositive(caseID: String, note: String) : void\n  }\n\n  class BankTeller {\n    - counterNumber : String\n    - branchID : String\n    + searchCustomerAccount(query: String) : BankAccount\n    + verifyCustomerIdentity(customerID: String, docDetails: Map) : boolean\n    + openNewAccount(customerID: String, type: String) : BankAccount\n    + closeAccount(accountID: String) : boolean\n    + modifyAccountDetails(accountID: String, data: Map) : void\n    + processDeposit(accountID: String, amount: double, type: String) : Transaction\n    + processWithdrawal(accountID: String, amount: double) : Transaction\n    + generateStatement(accountID: String, period: DateRange) : Statement\n    + requestSupervisorApproval(requestID: String) : void\n    + confirmIdentityMatch(customerID: String) : void\n  }\n\n  class FacilitiesManager {\n    - branchID : String\n    + openRosterModule() : void\n    + assignStaffToShift(staffID: String, shiftData: Map) : Shift\n    + validateRoster(rosterID: String) : boolean\n    + publishRoster(rosterID: String) : void\n    + reviewShifts(branchID: String, period: DateRange) : List\n    + assignITTicket(ticketID: String, technicianID: String, deadline: Date) : void\n    + rejectTicketClosure(ticketID: String, note: String) : void\n    + reviewIncidentReport(reportID: String) : void\n    + selectAssetForMaintenance(assetID: String) : MaintenanceTask\n    + createMaintenanceTask(assetID: String, data: Map) : MaintenanceTask\n    + confirmTaskClosure(taskID: String) : void\n    + reassignTaskForRework(taskID: String) : void\n    + generateFacilitiesReport(params: Map) : Report\n  }\n\n  class FacilitiesStaff {\n    - staffType : String\n    - branchID : String\n    + viewSchedule() : Schedule\n    + checkIn(shiftID: String) : void\n    + checkOut(shiftID: String) : void\n    + submitReport(reportData: Map) : Report\n    + updateTicketStatus(ticketID: String, status: String, notes: String) : void\n    + markMaintenanceComplete(taskID: String, notes: String) : void\n    + logTripDetails(tripData: Map) : void\n  }\n\n  class Customer {\n    - fullName : String\n    - dateOfBirth : Date\n    - nationalID : String\n    - address : String\n    - kycStatus : String\n    + viewAccountBalance(accountID: String) : double\n    + viewTransactionHistory(accountID: String) : List\n    + submitDepositRequest(accountID: String, amount: double, type: String) : Transaction\n    + submitWithdrawalRequest(accountID: String, amount: double) : Transaction\n    + submitFundTransfer(sourceID: String, destID: String, amount: double, type: String) : Transaction\n    + makeCardPayment(cardID: String, amount: double, merchantID: String) : Transaction\n    + applyForLoan(loanData: Map) : LoanApplication\n    + makeRepayment(loanID: String, amount: double, method: String) : void\n    + applyForCard(cardType: String) : CardApplication\n    + requestChequebook(accountID: String) : Chequebook\n    + updateSpendingLimit(cardID: String, newLimit: double) : void\n    + addBeneficiary(data: Map) : Beneficiary\n    + editBeneficiary(beneficiaryID: String, data: Map) : void\n    + deleteBeneficiary(beneficiaryID: String) : void\n    + submitComplaint(details: String, type: String) : Complaint\n    + requestDocument(docType: String) : DocumentRequest\n    + scheduleAppointment(branchID: String, date: DateTime) : Appointment\n    + viewNearbyATMsAndBranches(location: String) : List\n    + viewNotifications() : List\n    + reportFraud(txnIDs: List, description: String) : FraudCase\n    + updateContactInfo(data: Map) : void\n  }\n\n  class Role {\n    - roleID : String\n    - roleName : String\n    - description : String\n    + addPermission(permissionID: String) : void\n    + removePermission(permissionID: String) : void\n    + getPermissions() : List\n  }\n\n  class Permission {\n    - permissionID : String\n    - module : String\n    - action : String\n    - isGranted : boolean\n  }\n\n  class AuditLog {\n    - logID : String\n    - userID : String\n    - action : String\n    - module : String\n    - ipAddress : String\n    - timestamp : DateTime\n    - outcome : String\n    + record(userID: String, action: String, module: String, outcome: String) : void\n    + retrieve(filters: Map) : List\n  }\n\n  class SystemHealth {\n    - cpuUsage : double\n    - memoryUsage : double\n    - networkStatus : String\n    - dbPerformance : String\n    - activeAlerts : List\n    - lastChecked : DateTime\n    + getDashboard() : HealthReport\n    + triggerAlert(message: String, severity: String) : void\n    + scheduleMaintenanceWindow(date: DateTime, duration: int) : void\n    + logMaintenanceActivity(details: String) : void\n    + rollbackUpdate(patchID: String) : void\n  }\n\n  class HealthReport {\n    - reportID : String\n    - generatedAt : DateTime\n    - cpuSnapshot : double\n    - memorySnapshot : double\n    - networkStatus : String\n    - alertSummary : String\n  }\n\n  class Schedule {\n    - scheduleID : String\n    - staffID : String\n    - branchID : String\n    - period : DateRange\n    - shifts : List\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: ACCOUNT MANAGEMENT\n&#39; ================================================================\npackage \&quot;Account Management\&quot; #E9F7EF {\n\n  abstract class BankAccount {\n    - accountID : String\n    - accountNumber : String\n    - accountType : String\n    - status : String\n    - openedDate : Date\n    - closedDate : Date\n    - balance : double\n    - currency : String\n    - branchID : String\n    + getBalance() : double\n    + credit(amount: double) : void\n    + debit(amount: double) : boolean\n    + closeAccount() : boolean\n    + checkPendingTransactions() : boolean\n    + getTransactionHistory() : List\n    + validateData(data: Map) : boolean\n  }\n\n  class SavingsAccount {\n    - interestRate : double\n    - minimumBalance : double\n    + calculateInterest() : double\n    + applyMonthlyInterest() : void\n  }\n\n  class CurrentAccount {\n    - overdraftLimit : double\n    - monthlyFee : double\n    + applyMonthlyFee() : void\n    + checkOverdraft(amount: double) : boolean\n  }\n\n  class FixedDepositAccount {\n    - maturityDate : Date\n    - depositTerm : int\n    - fixedInterestRate : double\n    + calculateMaturityAmount() : double\n    + isMatured() : boolean\n  }\n\n  class LoanAccount {\n    - loanAmount : double\n    - interestRate : double\n    - loanTerm : int\n    - loanStatus : String\n    - remainingBalance : double\n    + calculateMonthlyRepayment() : double\n    + processRepayment(amount: double) : void\n    + getRemainingBalance() : double\n    + updateLoanBalance(amount: double) : void\n  }\n\n  class KYCDocument {\n    - documentID : String\n    - customerID : String\n    - documentType : String\n    - documentNumber : String\n    - issuedDate : Date\n    - expiryDate : Date\n    - isVerified : boolean\n    - fileRef : String\n    + verify() : boolean\n    + isExpired() : boolean\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: TRANSACTION MANAGEMENT\n&#39; ================================================================\npackage \&quot;Transaction Management\&quot; #FEF9E7 {\n\n  abstract class Transaction {\n    - transactionID : String\n    - transactionType : String\n    - amount : double\n    - currency : String\n    - status : String\n    - timestamp : DateTime\n    - referenceNumber : String\n    - sourceAccountID : String\n    - destinationAccountID : String\n    - actorID : String\n    + process() : boolean\n    + cancel() : boolean\n    + generateReference() : String\n    + getReceipt() : String\n  }\n\n  class Deposit {\n    - depositType : String\n    - clearingPeriod : int\n    - isOnHold : boolean\n    + processCashDeposit() : boolean\n    + processChequeDeposit() : boolean\n    + processElectronicDeposit() : boolean\n    + reverseProvisionalCredit() : void\n    + releaseHold() : void\n  }\n\n  class Withdrawal {\n    - withdrawalMethod : String\n    - dailyLimit : double\n    - atmID : String\n    + validateDailyLimit(amount: double) : boolean\n    + processATMWithdrawal() : boolean\n    + processBranchWithdrawal() : boolean\n    + authoriseCashRelease() : void\n  }\n\n  class FundTransfer {\n    - transferType : String\n    - isRecurring : boolean\n    - frequency : String\n    - scheduledDate : Date\n    - swiftCode : String\n    - isQueued : boolean\n    + validateDestinationAccount() : boolean\n    + processInternalTransfer() : boolean\n    + processWireTransfer() : boolean\n    + scheduleRecurringTransfer() : void\n    + queueTransfer() : void\n  }\n\n  class CardPayment {\n    - cardID : String\n    - merchantID : String\n    - paymentMethod : String\n    - isAuthorised : boolean\n    - isFlaggedForFraud : boolean\n    + authorise() : boolean\n    + reserveFunds() : void\n    + finalise() : void\n    + flagForFraud() : void\n    + requireOTPVerification() : boolean\n  }\n\n  class BulkPayment {\n    - batchID : String\n    - batchType : String\n    - totalAmount : double\n    - batchStatus : String\n    - paymentRecords : List\n    + validateBatch() : boolean\n    + calculateTotals() : double\n    + processBatch() : BatchReport\n    + flagErrorRecords() : List\n    + generateBatchReport() : BatchReport\n  }\n\n  class BeneficiaryTransfer {\n    - beneficiaryID : String\n    + executeTransfer() : boolean\n    + validateBeneficiary() : boolean\n  }\n\n  class BatchReport {\n    - batchID : String\n    - processedCount : int\n    - failedCount : int\n    - totalDisbursed : double\n    - failedRecords : List\n    - generatedAt : DateTime\n    + getFailedRecords() : List\n    + getSummary() : String\n  }\n\n  class PaymentRecord {\n    - recordID : String\n    - recipientAccountID : String\n    - amount : double\n    - status : String\n    - errorReason : String\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: CARD MANAGEMENT\n&#39; ================================================================\npackage \&quot;Card Management\&quot; #F4ECF7 {\n\n  class Card {\n    - cardID : String\n    - cardNumber : String\n    - cardType : String\n    - expiryDate : Date\n    - status : String\n    - spendingLimit : double\n    - linkedAccountID : String\n    - isBlocked : boolean\n    + activate() : void\n    + block() : void\n    + unblock() : void\n    + updateSpendingLimit(newLimit: double) : void\n    + isValid() : boolean\n    + isExpired() : boolean\n  }\n\n  class CardApplication {\n    - applicationID : String\n    - customerID : String\n    - cardType : String\n    - status : String\n    - submittedDate : DateTime\n    + submit() : void\n    + validate() : boolean\n    + approve() : Card\n    + reject() : void\n    + notifyCustomer() : void\n  }\n\n  class Chequebook {\n    - chequebookID : String\n    - accountID : String\n    - serialStart : String\n    - serialEnd : String\n    - issuedDate : Date\n    - status : String\n    + checkEligibility(accountID: String) : boolean\n    + issueChequebook() : void\n    + notifyCustomer() : void\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: LOAN MANAGEMENT\n&#39; ================================================================\npackage \&quot;Loan Management\&quot; #FDEDEC {\n\n  class LoanApplication {\n    - applicationID : String\n    - customerID : String\n    - loanAmount : double\n    - loanType : String\n    - status : String\n    - submittedDate : DateTime\n    - reviewedByStaffID : String\n    - reviewedByDirectorID : String\n    - isAboveThreshold : boolean\n    + submit() : void\n    + validate() : boolean\n    + sendToStaff() : void\n    + sendToDirector() : void\n    + approve() : LoanAccount\n    + reject() : void\n    + notifyCustomer() : void\n    + requestAdditionalInfo() : void\n  }\n\n  class Repayment {\n    - repaymentID : String\n    - loanID : String\n    - dueDate : Date\n    - amount : double\n    - status : String\n    - paidDate : Date\n    - paymentMethod : String\n    + processOnlineRepayment() : void\n    + processBranchRepayment() : void\n    + updateLoanBalance() : void\n    + sendConfirmation() : void\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: FRAUD DETECTION\n&#39; ================================================================\npackage \&quot;Fraud Detection\&quot; #FDEBD0 {\n\n  class FraudCase {\n    - caseID : String\n    - accountID : String\n    - reportedByCustomerID : String\n    - detectedDate : DateTime\n    - severity : String\n    - status : String\n    - description : String\n    - linkedTransactionIDs : List\n    - referenceNumber : String\n    - investigationNotes : String\n    - correctiveAction : String\n    + createCase(accountID: String, description: String) : void\n    + examine() : void\n    + selectCorrectiveAction(action: String) : void\n    + applyAction() : void\n    + closeCase() : void\n    + markAsFalsePositive(justification: String) : void\n    + notifyCustomer() : void\n    + generateReferenceNumber() : String\n  }\n\n  class FraudAlert {\n    - alertID : String\n    - eventType : String\n    - severity : String\n    - affectedAccountID : String\n    - detectedAt : DateTime\n    - status : String\n    - reviewedByDirectorID : String\n    - delegatedToStaffID : String\n    + generate(eventType: String, severity: String) : void\n    + deliverToDashboard() : void\n    + deliverExternalNotification() : void\n    + markAsReviewed(directorID: String) : void\n    + delegateToStaff(staffID: String) : void\n    + escalateToBackupContact() : void\n    + logDirectorResponse(response: String) : void\n  }\n\n  class FraudReport {\n    - reportID : String\n    - reportType : String\n    - configuredBy : String\n    - dateRange : DateRange\n    - params : Map\n    - generatedAt : DateTime\n    + generate() : void\n    + exportToPDF() : File\n    + exportToCSV() : File\n    + logAccess() : void\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: CUSTOMER SERVICES\n&#39; ================================================================\npackage \&quot;Customer Services\&quot; #EBF5FB {\n\n  class Complaint {\n    - complaintID : String\n    - customerID : String\n    - type : String\n    - description : String\n    - status : String\n    - submittedDate : DateTime\n    - resolvedDate : DateTime\n    - assignedToStaffID : String\n    + submit() : void\n    + assignToStaff(staffID: String) : void\n    + investigate() : void\n    + resolve(resolution: String) : void\n    + escalate(targetID: String) : void\n    + requestMoreInfo() : void\n    + notifyCustomer() : void\n  }\n\n  class Appointment {\n    - appointmentID : String\n    - customerID : String\n    - branchID : String\n    - scheduledDateTime : DateTime\n    - status : String\n    + checkAvailability(branchID: String, dateTime: DateTime) : boolean\n    + confirm() : void\n    + cancel() : void\n    + edit(newDateTime: DateTime) : void\n    + sendConfirmationNotification() : void\n  }\n\n  class Notification {\n    - notificationID : String\n    - recipientID : String\n    - type : String\n    - message : String\n    - channel : String\n    - status : String\n    - sentAt : DateTime\n    - retryCount : int\n    + send() : boolean\n    + retry() : void\n    + useFallbackChannel() : void\n    + markAsDelivered() : void\n  }\n\n  class DocumentRequest {\n    - requestID : String\n    - customerID : String\n    - documentType : String\n    - status : String\n    - requestedDate : DateTime\n    - deliveredDate : DateTime\n    + submit() : void\n    + validate() : boolean\n    + process() : void\n    + deliver() : void\n    + notifyDelay() : void\n    + notifyError() : void\n  }\n\n  class Statement {\n    - statementID : String\n    - accountID : String\n    - period : DateRange\n    - generatedDate : DateTime\n    - deliveryChannel : String\n    - transactions : List\n    + generate() : void\n    + send(channel: String) : boolean\n    + download() : File\n  }\n\n  class Beneficiary {\n    - beneficiaryID : String\n    - ownerCustomerID : String\n    - name : String\n    - accountNumber : String\n    - bankName : String\n    - swiftCode : String\n    - nickname : String\n    - isVerified : boolean\n    + validate() : boolean\n    + save() : void\n    + update(data: Map) : void\n    + remove() : void\n    + isDuplicate() : boolean\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: ANALYTICS &amp; REPORTING\n&#39; ================================================================\npackage \&quot;Analytics and Reporting\&quot; #EAFAF1 {\n\n  class Report {\n    - reportID : String\n    - reportType : String\n    - generatedByID : String\n    - generatedDate : DateTime\n    - parameters : Map\n    - content : String\n    + generate() : void\n    + exportToPDF() : File\n    + exportToCSV() : File\n    + logAccess() : void\n  }\n\n  class DateRange {\n    - startDate : Date\n    - endDate : Date\n    + isValid() : boolean\n    + getDuration() : int\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: FUND MANAGEMENT\n&#39; ================================================================\npackage \&quot;Fund Management\&quot; #FEF9E7 {\n\n  class FundAllocation {\n    - allocationID : String\n    - initiatedByDirectorID : String\n    - sourceUnit : String\n    - destinationUnit : String\n    - amount : double\n    - allocatedDate : DateTime\n    - status : String\n    - isQueued : boolean\n    + validateFunds() : boolean\n    + processAllocation() : void\n    + updateBalances() : void\n    + queueAllocation() : void\n    + generateTransactionRecord() : void\n  }\n\n  class BankPolicy {\n    - policyID : String\n    - policyType : String\n    - category : String\n    - previousValue : String\n    - newValue : String\n    - effectiveDate : Date\n    - updatedByDirectorID : String\n    + validateAgainstCompliance() : boolean\n    + apply() : void\n    + propagateToModules() : void\n    + logChange() : void\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: FACILITIES &amp; CHANGE MANAGEMENT\n&#39; ================================================================\npackage \&quot;Facilities and Change Management\&quot; #F9EBEA {\n\n  class Shift {\n    - shiftID : String\n    - rosterID : String\n    - staffID : String\n    - role : String\n    - post : String\n    - branchID : String\n    - startTime : DateTime\n    - endTime : DateTime\n    - checkInTime : DateTime\n    - checkOutTime : DateTime\n    - status : String\n    + assign(staffID: String) : void\n    + validate() : boolean\n    + publish() : void\n    + notifyStaff() : void\n    + recordCheckIn() : void\n    + recordCheckOut() : void\n    + flagMissingCheckOut() : void\n    + manualClose(managerID: String) : void\n  }\n\n  class ITTicket {\n    - ticketID : String\n    - submittedByID : String\n    - assignedToTechID : String\n    - description : String\n    - priority : String\n    - status : String\n    - submittedDate : DateTime\n    - deadline : Date\n    - resolutionNotes : String\n    + submit() : void\n    + assign(techID: String, deadline: Date) : void\n    + notifyTechnician() : void\n    + markResolved(notes: String) : void\n    + closeTicket() : void\n    + reopen(note: String) : void\n    + checkIfOverdue() : boolean\n    + sendOverdueAlert() : void\n  }\n\n  class MaintenanceTask {\n    - taskID : String\n    - assetID : String\n    - assignedWorkerID : String\n    - assignedByManagerID : String\n    - taskType : String\n    - description : String\n    - scheduledDate : Date\n    - completedDate : Date\n    - status : String\n    - qualityRating : String\n    - specialInstructions : String\n    - partsUsed : List\n    - completionNotes : String\n    + create(assetID: String, data: Map) : void\n    + assign(workerID: String) : void\n    + notifyWorker() : void\n    + markComplete(notes: String, partsUsed: List) : void\n    + defer(reason: String) : void\n    + reschedule(newDate: Date) : void\n    + closeTask() : void\n    + reassignForRework() : void\n    + notifyManager() : void\n  }\n\n  class Asset {\n    - assetID : String\n    - assetType : String\n    - branchID : String\n    - description : String\n    - condition : String\n    - purchaseDate : Date\n    - lastMaintenanceDate : Date\n    - status : String\n    + updateCondition(condition: String) : void\n    + flagForRepair() : void\n    + flagForDisposal() : void\n    + getMaintenanceHistory() : List\n  }\n\n  class IncidentReport {\n    - reportID : String\n    - submittedByStaffID : String\n    - branchID : String\n    - incidentDate : DateTime\n    - description : String\n    - status : String\n    + submit() : void\n    + notifyManager() : void\n    + review() : void\n    + resolve() : void\n  }\n}\n\n&#39; ================================================================\n&#39;  PACKAGE: BRANCH &amp; ATM\n&#39; ================================================================\npackage \&quot;Branch and ATM\&quot; #ECF0F1 {\n\n  class Branch {\n    - branchID : String\n    - branchName : String\n    - address : String\n    - phoneNumber : String\n    - managerID : String\n    - cashBalance : double\n    + getCashBalance() : double\n    + updateCashBalance(amount: double) : void\n    + getATMs() : List\n    + getStaff() : List\n  }\n\n  class ATM {\n    - atmID : String\n    - location : String\n    - branchID : String\n    - status : String\n    - cashBalance : double\n    - lastMaintenance : Date\n    + dispenseCash(amount: double) : boolean\n    + updateCashBalance(amount: double) : void\n    + reportStatus() : void\n    + retainCard(cardID: String) : void\n  }\n}\n\n&#39; ================================================================\n&#39;  USER INHERITANCE\n&#39; ================================================================\nUser &lt;|-- Administrator\nUser &lt;|-- BankDirector\nUser &lt;|-- BankStaff\nUser &lt;|-- BankTeller\nUser &lt;|-- FacilitiesManager\nUser &lt;|-- FacilitiesStaff\nUser &lt;|-- Customer\n\n&#39; ================================================================\n&#39;  ROLES &amp; PERMISSIONS\n&#39; ================================================================\nUser \&quot;1\&quot; -- \&quot;1\&quot; Role            : is assigned &gt;\nRole \&quot;1\&quot; *-- \&quot;many\&quot; Permission  : contains &gt;\n\n&#39; ================================================================\n&#39;  AUDIT LOG (cross-cutting)\n&#39; ================================================================\nAuditLog \&quot;many\&quot; --o \&quot;1\&quot; User    : recorded by &gt;\n\n&#39; ================================================================\n&#39;  SYSTEM HEALTH\n&#39; ================================================================\nAdministrator \&quot;1\&quot; --&gt; \&quot;1\&quot; SystemHealth : monitors &gt;\nSystemHealth ..&gt; HealthReport            : produces &gt;\n\n&#39; ================================================================\n&#39;  ACCOUNT MANAGEMENT\n&#39; ================================================================\nBankAccount &lt;|-- SavingsAccount\nBankAccount &lt;|-- CurrentAccount\nBankAccount &lt;|-- FixedDepositAccount\nBankAccount &lt;|-- LoanAccount\n\nCustomer \&quot;1\&quot; --o \&quot;many\&quot; BankAccount    : owns &gt;\nCustomer \&quot;1\&quot; --o \&quot;many\&quot; KYCDocument    : provides &gt;\nBankAccount \&quot;1\&quot; --o \&quot;many\&quot; KYCDocument : linked to &gt;\n\nBankStaff  \&quot;1\&quot; --&gt; \&quot;many\&quot; BankAccount  : manages &gt;\nBankTeller \&quot;1\&quot; --&gt; \&quot;many\&quot; BankAccount  : opens/closes/modifies &gt;\n\n&#39; ================================================================\n&#39;  TRANSACTION MANAGEMENT\n&#39; ================================================================\nTransaction &lt;|-- Deposit\nTransaction &lt;|-- Withdrawal\nTransaction &lt;|-- FundTransfer\nTransaction &lt;|-- CardPayment\nTransaction &lt;|-- BulkPayment\nTransaction &lt;|-- BeneficiaryTransfer\n\nBankAccount \&quot;1\&quot; --o \&quot;many\&quot; Transaction : records &gt;\n\nBulkPayment \&quot;1\&quot; *-- \&quot;many\&quot; PaymentRecord : contains &gt;\nBulkPayment \&quot;1\&quot; ..&gt; BatchReport         : generates &gt;\n\nCustomer  \&quot;1\&quot; --&gt; \&quot;many\&quot; Transaction  : initiates &gt;\nBankTeller \&quot;1\&quot; --&gt; \&quot;many\&quot; Transaction : processes &gt;\nBankStaff  \&quot;1\&quot; --&gt; \&quot;many\&quot; BulkPayment : processes &gt;\n\n&#39; ================================================================\n&#39;  CARD MANAGEMENT\n&#39; ================================================================\nCustomer \&quot;1\&quot; --o \&quot;many\&quot; Card            : holds &gt;\nCard \&quot;1\&quot; -- \&quot;1\&quot; BankAccount             : linked to &gt;\nCardApplication ..&gt; Card                : creates on approval &gt;\nCardApplication \&quot;many\&quot; --o \&quot;1\&quot; Customer : submitted by &gt;\nCardPayment \&quot;many\&quot; --o \&quot;1\&quot; Card         : uses &gt;\nChequebook \&quot;many\&quot; --o \&quot;1\&quot; Customer      : issued to &gt;\nChequebook \&quot;many\&quot; --o \&quot;1\&quot; BankAccount   : linked to &gt;\n\n&#39; ================================================================\n&#39;  LOAN MANAGEMENT\n&#39; ================================================================\nLoanApplication \&quot;many\&quot; --o \&quot;1\&quot; Customer     : submitted by &gt;\nLoanApplication ..&gt; LoanAccount             : creates on approval &gt;\nLoanAccount \&quot;1\&quot; *-- \&quot;many\&quot; Repayment        : has &gt;\nBankStaff   \&quot;1\&quot; --&gt; \&quot;many\&quot; LoanApplication  : reviews &gt;\nBankDirector \&quot;1\&quot; --&gt; \&quot;many\&quot; LoanApplication : approves/rejects &gt;\n\n&#39; ================================================================\n&#39;  FRAUD DETECTION\n&#39; ================================================================\nFraudCase \&quot;many\&quot; --o \&quot;1\&quot; BankAccount   : related to &gt;\nFraudCase \&quot;many\&quot; --o \&quot;1\&quot; Customer      : reported by &gt;\nFraudAlert \&quot;many\&quot; --o \&quot;1\&quot; BankDirector : delivered to &gt;\nFraudAlert ..&gt; FraudCase               : triggers &gt;\nBankStaff  \&quot;1\&quot; --&gt; \&quot;many\&quot; FraudCase    : investigates &gt;\nFraudReport ..&gt; FraudCase              : summarises &gt;\n\n&#39; ================================================================\n&#39;  CUSTOMER SERVICES\n&#39; ================================================================\nCustomer \&quot;1\&quot; --o \&quot;many\&quot; Complaint       : submits &gt;\nCustomer \&quot;1\&quot; --o \&quot;many\&quot; Appointment     : schedules &gt;\nCustomer \&quot;1\&quot; --o \&quot;many\&quot; Notification    : receives &gt;\nCustomer \&quot;1\&quot; --o \&quot;many\&quot; DocumentRequest : requests &gt;\nCustomer \&quot;1\&quot; --o \&quot;many\&quot; Beneficiary     : manages &gt;\nCustomer \&quot;1\&quot; --o \&quot;many\&quot; Statement       : receives &gt;\n\nBankAccount \&quot;1\&quot; --o \&quot;many\&quot; Statement    : generates &gt;\nBankTeller \&quot;1\&quot; --&gt; \&quot;many\&quot; Statement     : generates &gt;\nBankStaff  \&quot;1\&quot; --&gt; \&quot;many\&quot; Complaint     : handles &gt;\nDocumentRequest ..&gt; Statement           : may produce &gt;\n\nAppointment \&quot;many\&quot; --o \&quot;1\&quot; Branch       : booked at &gt;\n\n&#39; ================================================================\n&#39;  ANALYTICS &amp; REPORTING\n&#39; ================================================================\nBankDirector \&quot;1\&quot; --&gt; \&quot;many\&quot; Report  : views &gt;\nBankStaff    \&quot;1\&quot; --&gt; \&quot;many\&quot; Report  : views &gt;\nFacilitiesManager \&quot;1\&quot; --&gt; \&quot;many\&quot; Report : generates &gt;\n\n&#39; FIX 1: Replaced invalid \&quot;uses\&quot; keyword with proper dependency arrows\nStatement    ..&gt; DateRange : uses &gt;\nFundTransfer ..&gt; DateRange : uses &gt;\nReport       ..&gt; DateRange : uses &gt;\n\n&#39; ================================================================\n&#39;  FUND MANAGEMENT\n&#39; ================================================================\nBankDirector \&quot;1\&quot; --&gt; \&quot;many\&quot; FundAllocation : initiates &gt;\nFundAllocation \&quot;many\&quot; --o \&quot;1\&quot; Branch       : targets &gt;\nFundAllocation \&quot;many\&quot; --o \&quot;1\&quot; ATM          : targets &gt;\nBankDirector \&quot;1\&quot; --&gt; \&quot;many\&quot; BankPolicy     : sets &gt;\nBankPolicy ..&gt; BankAccount                 : affects &gt;\n\n&#39; ================================================================\n&#39;  FACILITIES &amp; CHANGE MANAGEMENT\n&#39; ================================================================\nFacilitiesManager \&quot;1\&quot; --&gt; \&quot;many\&quot; Shift            : creates/publishes &gt;\nShift \&quot;many\&quot; --o \&quot;1\&quot; FacilitiesStaff              : assigned to &gt;\nFacilitiesStaff \&quot;1\&quot; --&gt; \&quot;many\&quot; IncidentReport      : submits &gt;\nFacilitiesManager \&quot;1\&quot; --&gt; \&quot;many\&quot; IncidentReport    : reviews &gt;\n\nFacilitiesManager \&quot;1\&quot; --&gt; \&quot;many\&quot; ITTicket          : assigns/monitors &gt;\nITTicket \&quot;many\&quot; --o \&quot;1\&quot; FacilitiesStaff            : resolved by &gt;\n\nFacilitiesManager \&quot;1\&quot; --&gt; \&quot;many\&quot; MaintenanceTask   : schedules &gt;\nMaintenanceTask \&quot;many\&quot; --o \&quot;1\&quot; FacilitiesStaff     : performed by &gt;\nMaintenanceTask \&quot;many\&quot; --o \&quot;1\&quot; Asset               : performed on &gt;\n\nFacilitiesManager \&quot;1\&quot; --&gt; \&quot;many\&quot; Asset             : manages &gt;\nFacilitiesManager \&quot;1\&quot; --&gt; \&quot;many\&quot; Report            : submits to director &gt;\n\nSchedule \&quot;1\&quot; *-- \&quot;many\&quot; Shift                      : contains &gt;\nFacilitiesStaff \&quot;1\&quot; --&gt; \&quot;1\&quot; Schedule               : views &gt;\n\n&#39; ================================================================\n&#39;  BRANCH &amp; ATM\n&#39; ================================================================\nBranch \&quot;1\&quot; *-- \&quot;many\&quot; ATM    : contains &gt;\nBranch \&quot;1\&quot; *-- \&quot;many\&quot; Asset  : contains &gt;\n\n&#39; FIX 2: Removed erroneous \&quot;ATM is an Asset\&quot; aggregation line.\n&#39; ATM is physically contained within Branch (already covered above).\n&#39; The original line — ATM \&quot;1\&quot; --o \&quot;1\&quot; Asset : is an &gt; — was logically\n&#39; contradictory because Asset is already composed inside Branch.\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="GySHlMXJLQFxvWdlVrDZ-1">
