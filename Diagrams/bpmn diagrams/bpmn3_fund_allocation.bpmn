<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_FundAllocation" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_FundAllocation">
    <participant id="Pool_Director" name="Bank Director" processRef="Proc_Director" />
    <participant id="Pool_FundSystem" name="Banking System" processRef="Proc_FundSystem" />
    <participant id="Pool_TargetUnit" name="Target Branch / ATM Unit" processRef="Proc_TargetUnit" />
    <messageFlow id="mf_fa1" sourceRef="Task_DirectorSubmit" targetRef="Start_FundSys" />
    <messageFlow id="mf_fa2" sourceRef="Task_FundSysProcess" targetRef="Task_UnitReceive" />
    <messageFlow id="mf_fa3" sourceRef="Task_FundSysNotifyError" targetRef="Task_DirectorHandleError" />
    <messageFlow id="mf_fa4" sourceRef="Task_FundSysConfirm" targetRef="Task_DirectorReceiveConfirm" />
  </collaboration>
  <process id="Proc_Director" isExecutable="false">
    <laneSet id="LaneSet_Director">
      <lane id="Lane_Director" name="Bank Director">
        <flowNodeRef>Start_DirectorLogin</flowNodeRef>
        <flowNodeRef>Task_OpenFundModule</flowNodeRef>
        <flowNodeRef>Task_ReviewBalances</flowNodeRef>
        <flowNodeRef>Task_IdentifyNeed</flowNodeRef>
        <flowNodeRef>Task_EnterAmount</flowNodeRef>
        <flowNodeRef>Task_DirectorSubmit</flowNodeRef>
        <flowNodeRef>End_DirectorCancelled</flowNodeRef>
        <flowNodeRef>End_DirectorQueued</flowNodeRef>
        <flowNodeRef>GW_DirectorWait</flowNodeRef>
        <flowNodeRef>Task_SelectSourceDest</flowNodeRef>
        <flowNodeRef>Task_DirectorQueued</flowNodeRef>
        <flowNodeRef>GW_Retry</flowNodeRef>
        <flowNodeRef>Task_DirectorHandleError</flowNodeRef>
        <flowNodeRef>Task_DirectorConfirm</flowNodeRef>
        <flowNodeRef>Task_DirectorReceiveConfirm</flowNodeRef>
        <flowNodeRef>End_DirectorSuccess</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_DirectorLogin" name="Bank Director Authenticated">
      <outgoing>d_sf1</outgoing>
    </startEvent>
    <sequenceFlow id="d_sf1" sourceRef="Start_DirectorLogin" targetRef="Task_OpenFundModule" />
    <task id="Task_OpenFundModule" name="Navigate to Fund Allocation Module">
      <incoming>d_sf1</incoming>
      <outgoing>d_sf2</outgoing>
    </task>
    <sequenceFlow id="d_sf2" sourceRef="Task_OpenFundModule" targetRef="Task_ReviewBalances" />
    <task id="Task_ReviewBalances" name="Review Current Fund Allocations &#38; Balances (All Branches / ATMs)">
      <incoming>d_sf2</incoming>
      <outgoing>d_sf3</outgoing>
    </task>
    <sequenceFlow id="d_sf3" sourceRef="Task_ReviewBalances" targetRef="Task_IdentifyNeed" />
    <task id="Task_IdentifyNeed" name="Identify Units Requiring Allocation or Redistribution">
      <incoming>d_sf3</incoming>
      <outgoing>d_sf4</outgoing>
    </task>
    <sequenceFlow id="d_sf4" sourceRef="Task_IdentifyNeed" targetRef="Task_SelectSourceDest" />
    <sequenceFlow id="d_sf5" sourceRef="Task_SelectSourceDest" targetRef="Task_EnterAmount" />
    <task id="Task_EnterAmount" name="Enter Transfer Amount">
      <incoming>d_sf5</incoming>
      <outgoing>d_sf6</outgoing>
    </task>
    <sequenceFlow id="d_sf6" sourceRef="Task_EnterAmount" targetRef="Task_DirectorConfirm" />
    <sequenceFlow id="d_sf7" sourceRef="Task_DirectorConfirm" targetRef="Task_DirectorSubmit" />
    <task id="Task_DirectorSubmit" name="Submit Allocation Request">
      <incoming>d_sf7</incoming>
      <outgoing>d_sf8</outgoing>
    </task>
    <sequenceFlow id="d_sf8" sourceRef="Task_DirectorSubmit" targetRef="GW_DirectorWait" />
    <sequenceFlow id="d_sf9_confirm" sourceRef="GW_DirectorWait" targetRef="Task_DirectorReceiveConfirm" />
    <sequenceFlow id="d_sf9_error" sourceRef="GW_DirectorWait" targetRef="Task_DirectorHandleError" />
    <sequenceFlow id="d_sf9_queued" sourceRef="GW_DirectorWait" targetRef="Task_DirectorQueued" />
    <sequenceFlow id="d_sf10" sourceRef="Task_DirectorReceiveConfirm" targetRef="End_DirectorSuccess" />
    <sequenceFlow id="d_sf11" sourceRef="Task_DirectorHandleError" targetRef="GW_Retry" />
    <sequenceFlow id="d_sf12_retry" name="Yes — Adjust Amount" sourceRef="GW_Retry" targetRef="Task_EnterAmount" />
    <sequenceFlow id="d_sf12_cancel" name="No — Cancel" sourceRef="GW_Retry" targetRef="End_DirectorCancelled" />
    <sequenceFlow id="d_sf13" sourceRef="Task_DirectorQueued" targetRef="End_DirectorQueued" />
    <endEvent id="End_DirectorCancelled" name="Allocation Cancelled">
      <incoming>d_sf12_cancel</incoming>
    </endEvent>
    <endEvent id="End_DirectorQueued" name="Allocation Queued — Pending Unit Reconnection">
      <incoming>d_sf13</incoming>
    </endEvent>
    <eventBasedGateway id="GW_DirectorWait" name="Wait for System Response">
      <incoming>d_sf8</incoming>
      <outgoing>d_sf9_confirm</outgoing>
      <outgoing>d_sf9_error</outgoing>
      <outgoing>d_sf9_queued</outgoing>
    </eventBasedGateway>
    <task id="Task_SelectSourceDest" name="Select Source Unit (or Central Reserve) &#38; Destination Unit">
      <incoming>d_sf4</incoming>
      <outgoing>d_sf5</outgoing>
    </task>
    <receiveTask id="Task_DirectorQueued" name="Receive Queue Notification (Target Unit Offline)">
      <incoming>d_sf9_queued</incoming>
      <outgoing>d_sf13</outgoing>
    </receiveTask>
    <exclusiveGateway id="GW_Retry" name="Retry?">
      <incoming>d_sf11</incoming>
      <outgoing>d_sf12_retry</outgoing>
      <outgoing>d_sf12_cancel</outgoing>
    </exclusiveGateway>
    <receiveTask id="Task_DirectorHandleError" name="Receive Error Notification (Insufficient Funds / Limit Exceeded)">
      <incoming>d_sf9_error</incoming>
      <outgoing>d_sf11</outgoing>
    </receiveTask>
    <task id="Task_DirectorConfirm" name="Review &#38; Confirm Allocation Details">
      <incoming>d_sf6</incoming>
      <outgoing>d_sf7</outgoing>
    </task>
    <receiveTask id="Task_DirectorReceiveConfirm" name="Receive Allocation Confirmation &#38; Updated Balances">
      <incoming>d_sf9_confirm</incoming>
      <outgoing>d_sf10</outgoing>
    </receiveTask>
    <endEvent id="End_DirectorSuccess" name="Allocation Confirmed — Balances Updated">
      <incoming>d_sf10</incoming>
    </endEvent>
  </process>
  <process id="Proc_FundSystem" isExecutable="false">
    <startEvent id="Start_FundSys" name="Receive Allocation Request">
      <outgoing>fs_sf1</outgoing>
    </startEvent>
    <sequenceFlow id="fs_sf1" sourceRef="Start_FundSys" targetRef="Task_FundSysValidate" />
    <task id="Task_FundSysValidate" name="Validate: Check Source Balance, Policy &#38; Regulatory Limits">
      <incoming>fs_sf1</incoming>
      <outgoing>fs_sf2</outgoing>
    </task>
    <sequenceFlow id="fs_sf2" sourceRef="Task_FundSysValidate" targetRef="GW_FundValidation" />
    <sequenceFlow id="fs_sf3_ok" name="Valid" sourceRef="GW_FundValidation" targetRef="GW_TargetOnline" />
    <sequenceFlow id="fs_sf3_insuf" name="Insufficient Funds" sourceRef="GW_FundValidation" targetRef="Task_FundSysNotifyError" />
    <sequenceFlow id="fs_sf3_limit" name="Limit Exceeded" sourceRef="GW_FundValidation" targetRef="Task_FundSysNotifyError" />
    <exclusiveGateway id="GW_TargetOnline" name="Target Unit Online?">
      <incoming>fs_sf3_ok</incoming>
      <outgoing>fs_sf4_online</outgoing>
      <outgoing>fs_sf4_offline</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="fs_sf4_online" name="Yes" sourceRef="GW_TargetOnline" targetRef="Task_FundSysProcess" />
    <sequenceFlow id="fs_sf4_offline" name="No — Offline" sourceRef="GW_TargetOnline" targetRef="Task_FundSysQueue" />
    <task id="Task_FundSysProcess" name="Process Fund Movement — Debit Source, Credit Destination">
      <incoming>fs_sf4_online</incoming>
      <outgoing>fs_sf5</outgoing>
    </task>
    <sequenceFlow id="fs_sf5" sourceRef="Task_FundSysProcess" targetRef="Task_FundSysAudit" />
    <sequenceFlow id="fs_sf6" sourceRef="Task_FundSysAudit" targetRef="Task_FundSysConfirm" />
    <endEvent id="End_FundSysError" name="Allocation Blocked — Error Sent">
      <incoming>fs_sf8</incoming>
    </endEvent>
    <sequenceFlow id="fs_sf7" sourceRef="Task_FundSysConfirm" targetRef="End_FundSysSuccess" />
    <sequenceFlow id="fs_sf8" sourceRef="Task_FundSysNotifyError" targetRef="End_FundSysError" />
    <sequenceFlow id="fs_sf9" sourceRef="Task_FundSysQueue" targetRef="End_FundSysQueued" />
    <endEvent id="End_FundSysSuccess" name="Fund Movement Complete">
      <incoming>fs_sf7</incoming>
    </endEvent>
    <task id="Task_FundSysConfirm" name="Update Balances in Real Time &#38; Send Confirmation to Director">
      <incoming>fs_sf6</incoming>
      <outgoing>fs_sf7</outgoing>
    </task>
    <task id="Task_FundSysAudit" name="Log Transaction Record &#38; Audit Trail Entry">
      <incoming>fs_sf5</incoming>
      <outgoing>fs_sf6</outgoing>
    </task>
    <endEvent id="End_FundSysQueued" name="Allocation Queued">
      <incoming>fs_sf9</incoming>
    </endEvent>
    <task id="Task_FundSysQueue" name="Queue Allocation &#38; Notify Director — Unit Offline">
      <incoming>fs_sf4_offline</incoming>
      <outgoing>fs_sf9</outgoing>
    </task>
    <exclusiveGateway id="GW_FundValidation" name="Validation Result">
      <incoming>fs_sf2</incoming>
      <outgoing>fs_sf3_ok</outgoing>
      <outgoing>fs_sf3_insuf</outgoing>
      <outgoing>fs_sf3_limit</outgoing>
    </exclusiveGateway>
    <task id="Task_FundSysNotifyError" name="Send Error Notification to Director (Reason + Details)">
      <incoming>fs_sf3_insuf</incoming>
      <incoming>fs_sf3_limit</incoming>
      <outgoing>fs_sf8</outgoing>
    </task>
  </process>
  <process id="Proc_TargetUnit" isExecutable="false">
    <startEvent id="Task_UnitReceive" name="Receive Incoming Fund Transfer">
      <outgoing>u_sf1</outgoing>
    </startEvent>
    <sequenceFlow id="u_sf1" sourceRef="Task_UnitReceive" targetRef="Task_UnitUpdateBalance" />
    <task id="Task_UnitUpdateBalance" name="Update Local Cash Balance">
      <incoming>u_sf1</incoming>
      <outgoing>u_sf2</outgoing>
    </task>
    <sequenceFlow id="u_sf2" sourceRef="Task_UnitUpdateBalance" targetRef="Task_UnitAcknowledge" />
    <task id="Task_UnitAcknowledge" name="Acknowledge Receipt to Banking System">
      <incoming>u_sf2</incoming>
      <outgoing>u_sf3</outgoing>
    </task>
    <endEvent id="End_UnitReady" name="Unit Ready — Funds Available">
      <incoming>u_sf3</incoming>
    </endEvent>
    <sequenceFlow id="u_sf3" sourceRef="Task_UnitAcknowledge" targetRef="End_UnitReady" />
    <startEvent id="Task_UnitQueue" name="Unit Offline — Allocation Queued">
      <outgoing>u_sf4</outgoing>
    </startEvent>
    <sequenceFlow id="u_sf4" sourceRef="Task_UnitQueue" targetRef="Task_UnitReconnect" />
    <task id="Task_UnitReconnect" name="Unit Comes Back Online — Apply Queued Transfer">
      <incoming>u_sf4</incoming>
      <outgoing>u_sf5</outgoing>
    </task>
    <endEvent id="End_UnitQueued" name="Queued Funds Applied">
      <incoming>u_sf5</incoming>
    </endEvent>
    <sequenceFlow id="u_sf5" sourceRef="Task_UnitReconnect" targetRef="End_UnitQueued" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Fund">
    <bpmndi:BPMNPlane id="BPMNPlane_Fund" bpmnElement="Collab_FundAllocation">
      <bpmndi:BPMNShape id="Pool_Director_di" bpmnElement="Pool_Director" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="1400" height="375" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Director_di" bpmnElement="Lane_Director" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1370" height="375" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_DirectorLogin_di" bpmnElement="Start_DirectorLogin">
        <dc:Bounds x="192" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="165" y="255" width="94" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OpenFundModule_di" bpmnElement="Task_OpenFundModule">
        <dc:Bounds x="278" y="190" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewBalances_di" bpmnElement="Task_ReviewBalances">
        <dc:Bounds x="448" y="190" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IdentifyNeed_di" bpmnElement="Task_IdentifyNeed">
        <dc:Bounds x="638" y="190" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnterAmount_di" bpmnElement="Task_EnterAmount">
        <dc:Bounds x="998" y="190" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DirectorSubmit_di" bpmnElement="Task_DirectorSubmit">
        <dc:Bounds x="1348" y="190" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_DirectorCancelled_di" bpmnElement="End_DirectorCancelled">
        <dc:Bounds x="858" y="370" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="832" y="413" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_DirectorQueued_di" bpmnElement="End_DirectorQueued">
        <dc:Bounds x="688" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="658" y="355" width="98" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_DirectorWait_di" bpmnElement="GW_DirectorWait">
        <dc:Bounds x="1355" y="345" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1342" y="402" width="77" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SelectSourceDest_di" bpmnElement="Task_SelectSourceDest">
        <dc:Bounds x="798" y="120" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DirectorQueued_di" bpmnElement="Task_DirectorQueued">
        <dc:Bounds x="800" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Retry_di" bpmnElement="GW_Retry" isMarkerVisible="true">
        <dc:Bounds x="915" y="305" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="923" y="281" width="33" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DirectorHandleError_di" bpmnElement="Task_DirectorHandleError">
        <dc:Bounds x="1010" y="340" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DirectorConfirm_di" bpmnElement="Task_DirectorConfirm">
        <dc:Bounds x="1168" y="120" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DirectorReceiveConfirm_di" bpmnElement="Task_DirectorReceiveConfirm">
        <dc:Bounds x="1200" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_DirectorSuccess_di" bpmnElement="End_DirectorSuccess">
        <dc:Bounds x="1212" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1199" y="435" width="66" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="d_sf1_di" bpmnElement="d_sf1">
        <di:waypoint x="228" y="230" />
        <di:waypoint x="278" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="d_sf2_di" bpmnElement="d_sf2">
        <di:waypoint x="398" y="230" />
        <di:waypoint x="448" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="d_sf3_di" bpmnElement="d_sf3">
        <di:waypoint x="588" y="230" />
