        <di:waypoint x="1395" y="308" />
        <di:waypoint x="1395" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="d_sf9_confirm_di" bpmnElement="d_sf9_confirm">
        <di:waypoint x="1380" y="345" />
