        <di:waypoint x="968" y="230" />
        <di:waypoint x="998" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="d_sf6_di" bpmnElement="d_sf6">
        <di:waypoint x="1118" y="230" />
        <di:waypoint x="1143" y="230" />
        <di:waypoint x="1143" y="160" />
        <di:waypoint x="1168" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="d_sf7_di" bpmnElement="d_sf7">
        <di:waypoint x="1298" y="160" />
