        <di:waypoint x="762" y="330" />
        <di:waypoint x="724" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Pool_FundSystem_di" bpmnElement="Pool_FundSystem" isHorizontal="true">
        <dc:Bounds x="130" y="440" width="1400" height="330" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_FundSys_di" bpmnElement="Start_FundSys">
        <dc:Bounds x="192" y="551" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="162" y="594" width="96" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FundSysValidate_di" bpmnElement="Task_FundSysValidate">
        <dc:Bounds x="278" y="530" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_TargetOnline_di" bpmnElement="GW_TargetOnline" isMarkerVisible="true">
        <dc:Bounds x="588" y="545" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="585" y="507.5" width="55" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FundSysProcess_di" bpmnElement="Task_FundSysProcess">
        <dc:Bounds x="698" y="530" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_FundSysError_di" bpmnElement="End_FundSysError">
        <dc:Bounds x="688" y="651" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="654" y="694" width="106" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_FundSysSuccess_di" bpmnElement="End_FundSysSuccess">
        <dc:Bounds x="1442" y="532" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1421" y="575" width="81" height="27" />
        </bpmndi:BPMNLabel>
