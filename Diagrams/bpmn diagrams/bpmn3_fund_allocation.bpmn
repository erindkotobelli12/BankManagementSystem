      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="d_sf10_di" bpmnElement="d_sf10">
        <di:waypoint x="1250" y="330" />
        <di:waypoint x="1250" y="361" />
        <di:waypoint x="1244" y="361" />
        <di:waypoint x="1244" y="399" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="d_sf11_di" bpmnElement="d_sf11">
        <di:waypoint x="1010" y="380" />
        <di:waypoint x="940" y="380" />
        <di:waypoint x="940" y="355" />
      </bpmndi:BPMNEdge>
