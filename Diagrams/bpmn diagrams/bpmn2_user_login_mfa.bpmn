        <bpmndi:BPMNLabel>
          <dc:Bounds x="574" y="393" width="106" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="u_sf1_di" bpmnElement="u_sf1">
