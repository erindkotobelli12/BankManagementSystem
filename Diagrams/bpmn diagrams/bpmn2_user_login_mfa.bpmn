<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Login" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_Login">
    <participant id="Pool_User" name="User (Any Role)" processRef="Proc_User" />
    <participant id="Pool_BankSystem" name="Banking System" processRef="Proc_BankSystem" />
    <participant id="Pool_MFAService" name="MFA Service (SMS / Authenticator)" processRef="Proc_MFAService" />
    <messageFlow id="mf_login1" sourceRef="Task_SubmitCredentials" targetRef="Task_SysReceiveCreds" />
    <messageFlow id="mf_login2" sourceRef="Task_SysOTPSend" targetRef="Task_MFASend" />
    <messageFlow id="mf_login3" sourceRef="Task_MFADeliver" targetRef="Task_UserReceiveOTP" />
    <messageFlow id="mf_login4" sourceRef="Task_UserSubmitOTP" targetRef="Task_SysVerifyOTP" />
    <messageFlow id="mf_login5" sourceRef="Task_SysIssueToken" targetRef="Task_UserDashboard" />
  </collaboration>
  <process id="Proc_User" isExecutable="false">
    <startEvent id="Start_UserNavigate" name="Navigate to Login Page">
      <outgoing>u_sf1</outgoing>
    </startEvent>
    <sequenceFlow id="u_sf1" sourceRef="Start_UserNavigate" targetRef="Task_EnterCredentials" />
    <task id="Task_EnterCredentials" name="Enter Username &#38; Password">
      <incoming>u_sf1</incoming>
      <outgoing>u_sf2</outgoing>
    </task>
    <sequenceFlow id="u_sf2" sourceRef="Task_EnterCredentials" targetRef="Task_SubmitCredentials" />
    <task id="Task_SubmitCredentials" name="Submit Login Request">
      <incoming>u_sf2</incoming>
      <incoming>u_sf_retry</incoming>
      <outgoing>u_sf3</outgoing>
    </task>
    <sequenceFlow id="u_sf3" sourceRef="Task_SubmitCredentials" targetRef="GW_CredResult" />
    <exclusiveGateway id="GW_CredResult" name="Credentials Accepted?">
      <incoming>u_sf3</incoming>
      <outgoing>u_sf4_ok</outgoing>
      <outgoing>u_sf4_fail</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="u_sf4_ok" name="Yes" sourceRef="GW_CredResult" targetRef="Task_UserReceiveOTP" />
    <sequenceFlow id="u_sf4_fail" name="No" sourceRef="GW_CredResult" targetRef="GW_AccountLocked" />
    <exclusiveGateway id="GW_AccountLocked" name="Max Attempts Reached?">
      <incoming>u_sf4_fail</incoming>
      <outgoing>u_sf5_locked</outgoing>
      <outgoing>u_sf5_retry</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="u_sf5_locked" name="Yes — Account Locked" sourceRef="GW_AccountLocked" targetRef="End_Locked" />
    <sequenceFlow id="u_sf5_retry" name="No — Retry" sourceRef="GW_AccountLocked" targetRef="Task_EnterCredentials" />
    <sequenceFlow id="u_sf_retry" sourceRef="Task_ResendOTP" targetRef="Task_SubmitCredentials" />
    <receiveTask id="Task_UserReceiveOTP" name="Receive OTP (SMS / App)">
      <incoming>u_sf4_ok</incoming>
      <outgoing>u_sf6</outgoing>
    </receiveTask>
    <sequenceFlow id="u_sf6" sourceRef="Task_UserReceiveOTP" targetRef="Task_UserSubmitOTP" />
    <task id="Task_UserSubmitOTP" name="Enter OTP within Time Window">
      <incoming>u_sf6</incoming>
      <outgoing>u_sf7</outgoing>
    </task>
    <sequenceFlow id="u_sf7" sourceRef="Task_UserSubmitOTP" targetRef="GW_OTPResult" />
    <exclusiveGateway id="GW_OTPResult" name="OTP Valid?">
      <incoming>u_sf7</incoming>
      <outgoing>u_sf8_ok</outgoing>
      <outgoing>u_sf8_expired</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="u_sf8_ok" name="Valid" sourceRef="GW_OTPResult" targetRef="Task_UserDashboard" />
    <sequenceFlow id="u_sf8_expired" name="Expired / Invalid" sourceRef="GW_OTPResult" targetRef="Task_ResendOTP" />
    <task id="Task_ResendOTP" name="Request New OTP (Resend)">
      <incoming>u_sf8_expired</incoming>
      <outgoing>u_sf_resend</outgoing>
    </task>
    <sequenceFlow id="u_sf_resend" sourceRef="Task_ResendOTP" targetRef="Task_UserReceiveOTP" />
    <receiveTask id="Task_UserDashboard" name="Access Role-Specific Dashboard">
      <incoming>u_sf8_ok</incoming>
      <outgoing>u_sf9</outgoing>
    </receiveTask>
    <sequenceFlow id="u_sf9" sourceRef="Task_UserDashboard" targetRef="End_LoggedIn" />
    <endEvent id="End_LoggedIn" name="Session Active — User Logged In">
      <incoming>u_sf9</incoming>
    </endEvent>
    <endEvent id="End_Locked" name="Account Locked — Contact Administrator">
      <incoming>u_sf5_locked</incoming>
    </endEvent>
  </process>
  <process id="Proc_BankSystem" isExecutable="false">
    <startEvent id="Task_SysReceiveCreds" name="Receive Login Request">
      <outgoing>bs_sf1</outgoing>
    </startEvent>
    <sequenceFlow id="bs_sf1" sourceRef="Task_SysReceiveCreds" targetRef="Task_SysValidateCreds" />
    <task id="Task_SysValidateCreds" name="Validate Username &#38; Password Against DB">
      <incoming>bs_sf1</incoming>
      <outgoing>bs_sf2</outgoing>
    </task>
    <sequenceFlow id="bs_sf2" sourceRef="Task_SysValidateCreds" targetRef="GW_SysCredValid" />
    <exclusiveGateway id="GW_SysCredValid" name="Valid?">
      <incoming>bs_sf2</incoming>
      <outgoing>bs_sf3_ok</outgoing>
      <outgoing>bs_sf3_fail</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="bs_sf3_ok" name="Yes" sourceRef="GW_SysCredValid" targetRef="Task_SysOTPSend" />
    <sequenceFlow id="bs_sf3_fail" name="No" sourceRef="GW_SysCredValid" targetRef="Task_SysIncrementFail" />
    <task id="Task_SysOTPSend" name="Trigger MFA — Generate &#38; Send OTP">
      <incoming>bs_sf3_ok</incoming>
      <outgoing>bs_sf4</outgoing>
    </task>
    <sequenceFlow id="bs_sf4" sourceRef="Task_SysOTPSend" targetRef="Task_SysVerifyOTP" />
    <task id="Task_SysIncrementFail" name="Increment Failed Attempt Counter">
      <incoming>bs_sf3_fail</incoming>
      <outgoing>bs_sf5</outgoing>
    </task>
    <sequenceFlow id="bs_sf5" sourceRef="Task_SysIncrementFail" targetRef="GW_SysMaxFail" />
    <exclusiveGateway id="GW_SysMaxFail" name="≥5 Failures?">
      <incoming>bs_sf5</incoming>
      <outgoing>bs_sf6_lock</outgoing>
      <outgoing>bs_sf6_error</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="bs_sf6_lock" name="Yes" sourceRef="GW_SysMaxFail" targetRef="Task_SysLockAccount" />
    <sequenceFlow id="bs_sf6_error" name="No" sourceRef="GW_SysMaxFail" targetRef="Task_SysShowError" />
    <task id="Task_SysLockAccount" name="Lock Account &#38; Notify User">
      <incoming>bs_sf6_lock</incoming>
      <outgoing>bs_sf7</outgoing>
    </task>
    <sequenceFlow id="bs_sf9" sourceRef="Task_SysVerifyOTP" targetRef="GW_SysOTPValid" />
    <sequenceFlow id="bs_sf10_fail" name="No" sourceRef="GW_SysOTPValid" targetRef="Task_SysOTPExpired" />
    <sequenceFlow id="bs_sf7" sourceRef="Task_SysLockAccount" targetRef="End_SysLocked" />
    <sequenceFlow id="bs_sf8" sourceRef="Task_SysShowError" targetRef="End_SysRetry" />
    <sequenceFlow id="bs_sf11" sourceRef="Task_SysIssueToken" targetRef="End_SysSession" />
    <sequenceFlow id="bs_sf12" sourceRef="Task_SysOTPExpired" targetRef="End_OTPExpired" />
    <endEvent id="End_SysSession" name="Active Session Created">
      <incoming>bs_sf11</incoming>
    </endEvent>
    <endEvent id="End_OTPExpired" name="OTP Resend Triggered">
      <incoming>bs_sf12</incoming>
    </endEvent>
    <task id="Task_SysOTPExpired" name="Notify OTP Expired — Offer Resend">
      <incoming>bs_sf10_fail</incoming>
      <outgoing>bs_sf12</outgoing>
    </task>
    <task id="Task_SysIssueToken" name="Issue Secure Session Token &#38; Log Audit Entry">
      <incoming>bs_sf10_ok</incoming>
      <outgoing>bs_sf11</outgoing>
    </task>
    <endEvent id="End_SysLocked" name="Account Locked">
      <incoming>bs_sf7</incoming>
    </endEvent>
    <sequenceFlow id="bs_sf10_ok" name="Yes" sourceRef="GW_SysOTPValid" targetRef="Task_SysIssueToken" />
    <exclusiveGateway id="GW_SysOTPValid" name="OTP Correct &#38; Not Expired?">
      <incoming>bs_sf9</incoming>
      <outgoing>bs_sf10_fail</outgoing>
      <outgoing>bs_sf10_ok</outgoing>
    </exclusiveGateway>
    <endEvent id="End_SysRetry" name="Retry Prompted">
      <incoming>bs_sf8</incoming>
    </endEvent>
    <task id="Task_SysShowError" name="Display Error — Incorrect Credentials">
      <incoming>bs_sf6_error</incoming>
      <outgoing>bs_sf8</outgoing>
    </task>
    <receiveTask id="Task_SysVerifyOTP" name="Verify OTP Submitted by User">
      <incoming>bs_sf4</incoming>
      <outgoing>bs_sf9</outgoing>
    </receiveTask>
  </process>
  <process id="Proc_MFAService" isExecutable="false">
    <startEvent id="Task_MFASend" name="Receive OTP Delivery Request">
      <outgoing>mfa_sf1</outgoing>
    </startEvent>
    <sequenceFlow id="mfa_sf1" sourceRef="Task_MFASend" targetRef="Task_MFAGenerateOTP" />
    <task id="Task_MFAGenerateOTP" name="Generate One-Time Password">
      <incoming>mfa_sf1</incoming>
      <outgoing>mfa_sf2</outgoing>
    </task>
    <sequenceFlow id="mfa_sf2" sourceRef="Task_MFAGenerateOTP" targetRef="Task_MFADeliver" />
    <task id="Task_MFADeliver" name="Deliver OTP via SMS or Authenticator App">
      <incoming>mfa_sf2</incoming>
      <outgoing>mfa_sf3</outgoing>
    </task>
    <endEvent id="End_MFADone" name="OTP Delivered">
      <incoming>mfa_sf3</incoming>
    </endEvent>
    <sequenceFlow id="mfa_sf3" sourceRef="Task_MFADeliver" targetRef="End_MFADone" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Login">
    <bpmndi:BPMNPlane id="BPMNPlane_Login" bpmnElement="Collab_Login">
      <bpmndi:BPMNShape id="Pool_User_di" bpmnElement="Pool_User" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="1260" height="220" />
      </bpmndi:BPMNShape>
