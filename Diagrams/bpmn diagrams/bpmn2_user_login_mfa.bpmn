        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SysOTPExpired_di" bpmnElement="Task_SysOTPExpired">
        <dc:Bounds x="1220" y="649" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SysIssueToken_di" bpmnElement="Task_SysIssueToken">
        <dc:Bounds x="1220" y="549" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_SysOTPValid_di" bpmnElement="GW_SysOTPValid" isMarkerVisible="true">
        <dc:Bounds x="1075" y="595" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1063" y="557.5" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_SysRetry_di" bpmnElement="End_SysRetry">
        <dc:Bounds x="1142" y="492" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1126" y="533" width="78" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SysShowError_di" bpmnElement="Task_SysShowError">
        <dc:Bounds x="935" y="480" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SysVerifyOTP_di" bpmnElement="Task_SysVerifyOTP">
        <dc:Bounds x="795" y="560" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="bs_sf1_di" bpmnElement="bs_sf1">
        <di:waypoint x="218" y="589" />
        <di:waypoint x="268" y="589" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="bs_sf2_di" bpmnElement="bs_sf2">
        <di:waypoint x="398" y="589" />
        <di:waypoint x="448" y="589" />
